BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//geek-calendar//EN
CALSCALE:GREGORIAN
METHOD:PUBLISH
X-WR-CALNAME:Geek Calendar
X-WR-CALDESC:Punny\, meme-y\, in-joke geek holidays. May the 4th\, Pi Day\, Towel Day\, Mole Day\, Talk Like a Pirate Day\, Mario Day\, Hobbit Day\, and friends.
X-WR-TIMEZONE:UTC
X-PUBLISHED-TTL:P7D
REFRESH-INTERVAL;VALUE=DURATION:P7D
BEGIN:VEVENT
UID:unix-epoch-bday@geek-calendar
DTSTAMP:20260504T000000Z
SUMMARY:🎂 Happy Birthday\, Unix
DESCRIPTION:1 January 1970 — the Unix epoch. Time itself was born. Whisper "time_t = 0" into a terminal at midnight.
DTSTART;VALUE=DATE:19700101
DTEND;VALUE=DATE:19700102
RRULE:FREQ=YEARLY
END:VEVENT
